# Copy this file to `.env` on your EC2 server before running docker compose.

# Public URL of your EC2/domain. For raw EC2 IP, use http://YOUR_EC2_PUBLIC_IP
APP_URL=http://your-domain-or-ec2-ip
FRONTEND_URL=http://your-domain-or-ec2-ip
VITE_API_URL=/api

# PostgreSQL container credentials
POSTGRES_USER=hurix
POSTGRES_PASSWORD=change-this-postgres-password
POSTGRES_DB=hurix_talent
DATABASE_URL=postgresql://hurix:change-this-postgres-password@postgres:5432/hurix_talent?schema=public

# JWT secrets - replace with long random values
JWT_ASSESSMENT_SECRET=change-this-long-random-assessment-secret
JWT_ADMIN_SECRET=change-this-long-random-admin-secret
ASSESSMENT_TOKEN_EXPIRY_DAYS=7
CANDIDATE_PORTAL_EXPIRY_DAYS=30
ADMIN_TOKEN_EXPIRY_HOURS=8
EMAIL_VERIFICATION_EXPIRY_HOURS=24

# Admin seed credentials
ADMIN_EMAIL=admin@hurixdigital.com
ADMIN_PASSWORD=change-this-admin-password
INIT_DB_ON_START=true

# Supabase Auth
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OAuth
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# OpenAI
OPENAI_API_KEY=
AI_SCORING_MODEL=gpt-4o-mini

# SMTP
EMAIL_PROVIDER=smtp
EMAIL_MOCK_MODE=false
EMAIL_FROM=Hurix Talent <noreply@hurixdigital.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Uploads
STORAGE_PROVIDER=local
UPLOAD_DIR=/app/uploads/resumes
MAX_RESUME_SIZE_MB=5

# Assessment
ASSESSMENT_QUESTION_COUNT=10
ASSESSMENT_DURATION_MINUTES=60
