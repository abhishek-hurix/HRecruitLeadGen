{
  "name": "hurix-talent-api",
  "version": "1.0.0",
  "description": "Hurix Talent Assessment Platform API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && npm run prisma:seed",
    "candidates:delete-all": "tsx scripts/delete-all-candidates.ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration tests/unit/visitor.service.test.ts tests/unit/analytics.service.test.ts",
    "test:security": "vitest run tests/security",
    "test:security-legacy": "tsx scripts/security-test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:db:setup": "tsx scripts/setup-test-db.ts && tsx scripts/migrate-test-db.ts",
    "test:e2e": "tsx scripts/e2e-test.ts",
    "test:attribution": "tsx scripts/attribution-test.ts",
    "test:visitor-dedup": "tsx scripts/visitor-dedup-test.ts",
    "test:hygiene": "tsx scripts/hygiene-test.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/pdf-parse": "^1.1.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.6",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^1.1.1",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "axios": "^1.18.0",
    "pg": "^8.13.1",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
