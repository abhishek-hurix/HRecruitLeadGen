generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Language {
  PYTHON
  JAVASCRIPT
}

enum Difficulty {
  EASY
  EASY_MEDIUM
  MEDIUM
  HARD
}

enum AssessmentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum SelectionStatus {
  PENDING
  SHORTLISTED
  INTERVIEWED
  SELECTED
  REJECTED
}

enum TokenStatus {
  CREATED
  EMAIL_SENT
  VERIFIED
  STARTED
  SUBMITTED
  EXPIRED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  BOTH
}

enum CandidateStatus {
  REGISTERED
  EMAIL_SENT
  VERIFIED
  STARTED
  SUBMITTED
  EXPIRED
}

enum CandidateAssessmentStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
}

enum DeviceType {
  DESKTOP
  TABLET
  MOBILE
}

enum JobRoleStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum CompensationType {
  HOURLY
  MONTHLY
  ANNUAL
}

enum ExperienceCategory {
  FRESHER
  ONE_YEAR
  TWO_YEARS
  THREE_YEARS
  FOUR_YEARS
  FIVE_YEARS
  SIX_YEARS
  SEVEN_YEARS
  EIGHT_YEARS
  NINE_YEARS
  TEN_YEARS
  ZERO_ONE
  ONE_TWO
  TWO_THREE
  THREE_FIVE
  FIVE_SEVEN
  SEVEN_TEN
  TEN_PLUS
}

enum AnswerMode {
  CODE
  COMPREHENSIVE
  MCQ
}

model Visitor {
  id                 String     @id @default(uuid())
  visitorId          String     @unique @map("visitor_id")
  firstTouchSource   String     @default("ORGANIC") @map("first_touch_source")
  firstTouchMedium   String?    @map("first_touch_medium")
  firstTouchCampaign String?    @map("first_touch_campaign")
  firstTouchTerm     String?    @map("first_touch_term")
  firstTouchContent  String?    @map("first_touch_content")
  lastTouchSource    String     @default("ORGANIC") @map("last_touch_source")
  lastTouchMedium    String?    @map("last_touch_medium")
  lastTouchCampaign  String?    @map("last_touch_campaign")
  lastTouchTerm      String?    @map("last_touch_term")
  lastTouchContent   String?    @map("last_touch_content")
  landingPage        String     @map("landing_page") @db.Text
  referrer           String?    @db.Text
  deviceType         DeviceType @default(DESKTOP) @map("device_type")
  firstVisitedAt     DateTime   @default(now()) @map("first_visited_at")
  lastVisitedAt      DateTime   @default(now()) @map("last_visited_at")
  candidateId        String?    @unique @map("candidate_id")
  registeredAt       DateTime?  @map("registered_at")
  isTest             Boolean    @default(false) @map("is_test")
  isInternal         Boolean    @default(false) @map("is_internal")

  candidate CandidateProfile? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([firstTouchSource])
  @@index([lastTouchSource])
  @@index([lastTouchCampaign])
  @@index([deviceType])
  @@index([firstVisitedAt])
  @@index([isTest])
  @@index([isInternal])
  @@map("visitors")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String?      @map("password_hash")
  supabaseUserId String?      @unique @map("supabase_user_id")
  googleId       String?      @unique @map("google_id")
  authProvider   AuthProvider @default(LOCAL) @map("auth_provider")
  lastLoginAt    DateTime?    @map("last_login_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  candidateProfiles CandidateProfile[]

  @@index([googleId])
  @@index([supabaseUserId])
  @@map("users")
}

model CandidateProfile {
  id                              String                    @id @default(uuid())
  userId                          String                    @map("user_id")
  fullName                        String                    @map("full_name")
  phone                           String
  countryCode                     String                    @default("+91") @map("country_code")
  phoneNumber                     String?                   @map("phone_number")
  fullPhone                       String?                   @map("full_phone")
  phoneCountry                    String                    @default("India") @map("phone_country")
  yearsOfExperience               Int?                      @map("years_of_experience")
  experienceCategory              ExperienceCategory?       @map("experience_category")
  linkedinUrl                     String                    @map("linkedin_url")
  resumePath                      String                    @map("resume_path")
  appliedRole                     String                    @default("General") @map("applied_role")
  referralCode                    String?                   @map("referral_code")
  emailVerified                   Boolean                   @default(false) @map("email_verified")
  emailVerifiedAt                 DateTime?                 @map("email_verified_at")
  verificationSentAt              DateTime?                 @map("verification_sent_at")
  verificationAttempts            Int                       @default(0) @map("verification_attempts")
  verificationAttemptsWindowStart DateTime?                 @map("verification_attempts_window_start")
  candidateStatus                 CandidateStatus           @default(REGISTERED) @map("candidate_status")
  assessmentStatus                CandidateAssessmentStatus @default(NOT_STARTED) @map("assessment_status")
  assessmentDate                  DateTime?                 @map("assessment_date")
  selectionStatus                 SelectionStatus           @default(PENDING) @map("selection_status")
  visitorId                       String?                   @unique @map("visitor_id")
  utmSource                       String?                   @map("utm_source")
  utmMedium                       String?                   @map("utm_medium")
  utmCampaign                     String?                   @map("utm_campaign")
  utmTerm                         String?                   @map("utm_term")
  utmContent                      String?                   @map("utm_content")
  firstTouchSource                String?                   @map("first_touch_source")
  lastTouchSource                 String?                   @map("last_touch_source")
  attributionLandingPage          String?                   @map("attribution_landing_page") @db.Text
  attributionReferrer             String?                   @map("attribution_referrer") @db.Text
  attributionDevice               DeviceType?               @map("attribution_device")
  selectedRoleId                  String?                   @map("selected_role_id")
  selectedRoleName                String?                   @map("selected_role_name")
  selectedCountry                 String?                   @map("selected_country")
  selectedCompensation            String?                   @map("selected_compensation")
  selectedSkills                  Json?                     @map("selected_skills")
  roleSelectedAt                  DateTime?                 @map("role_selected_at")
  deletedAt                       DateTime?                 @map("deleted_at")
  deletedByAdminId                String?                   @map("deleted_by_admin_id")
  restoredAt                      DateTime?                 @map("restored_at")
  restoredByAdminId               String?                   @map("restored_by_admin_id")
  // Latest rejection snapshot (denormalized). Full history lives in CandidateRejection.
  rejectionReason                 String?                   @map("rejection_reason") @db.Text
  rejectedAt                      DateTime?                 @map("rejected_at")
  rejectedByAdminId               String?                   @map("rejected_by_admin_id")
  previousSelectionStatus         SelectionStatus?          @map("previous_selection_status")
  createdAt                       DateTime                  @default(now()) @map("created_at")
  updatedAt                       DateTime                  @updatedAt @map("updated_at")

  user                    User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  visitor                 Visitor?
  selectedRole            JobRole?                        @relation(fields: [selectedRoleId], references: [id], onDelete: SetNull)
  deletedByAdmin          AdminUser?                      @relation("CandidateDeletedBy", fields: [deletedByAdminId], references: [id], onDelete: SetNull)
  restoredByAdmin         AdminUser?                      @relation("CandidateRestoredBy", fields: [restoredByAdminId], references: [id], onDelete: SetNull)
  rejectedByAdmin         AdminUser?                      @relation("CandidateRejectedBy", fields: [rejectedByAdminId], references: [id], onDelete: SetNull)
  assessmentTokens        AssessmentToken[]
  emailVerificationTokens EmailVerificationToken[]
  assessments             Assessment[]
  submissions             Submission[]
  resumes                 CandidateResume[]
  interviewParticipants   CandidateInterviewParticipant[]
  reminderDeliveries      EmailReminderDelivery[]
  bulkOperationItems      AdminBulkOperationItem[]
  rejectionHistory        CandidateRejection[]

  @@index([emailVerified])
  @@index([selectedRoleId])
  @@index([deletedAt])
  @@index([deletedAt, createdAt])
  @@index([selectionStatus])
  @@index([candidateStatus])
  @@index([candidateStatus, deletedAt, createdAt])
  @@index([selectedRoleId, deletedAt, createdAt])
  @@index([phoneCountry, deletedAt])
  @@index([assessmentStatus, deletedAt])
  @@index([createdAt])
  @@index([fullName])
  @@map("candidate_profiles")
}

/// Restricted rejection history. Reasons are Super-Admin-only via service layer.
model CandidateRejection {
  id                      String           @id @default(uuid())
  candidateId             String?          @map("candidate_id")
  candidateReference      String           @map("candidate_reference")
  rejectedByAdminId       String?          @map("rejected_by_admin_id")
  previousJourneyStatus   String?          @map("previous_journey_status")
  previousSelectionStatus SelectionStatus? @map("previous_selection_status")
  reason                  String           @db.Text
  rejectedAt              DateTime         @default(now()) @map("rejected_at")
  operationId             String?          @map("operation_id")
  createdAt               DateTime         @default(now()) @map("created_at")

  candidate       CandidateProfile? @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  rejectedByAdmin AdminUser?        @relation("CandidateRejectionBy", fields: [rejectedByAdminId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@index([rejectedAt])
  @@index([operationId])
  @@index([candidateId, rejectedAt])
  @@map("candidate_rejections")
}

model CandidateResume {
  id          String   @id @default(uuid())
  candidateId String   @map("candidate_id")
  fileName    String   @map("file_name")
  filePath    String   @map("file_path")
  isPrimary   Boolean  @default(false) @map("is_primary")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([candidateId, isPrimary])
  @@map("candidate_resumes")
}

model JobRole {
  id                   String           @id @default(uuid())
  title                String
  country              String
  compensationType     CompensationType @map("compensation_type")
  hourlyRate           Decimal?         @map("hourly_rate") @db.Decimal(12, 2)
  monthlySalary        Decimal?         @map("monthly_salary") @db.Decimal(14, 2)
  currency             String           @default("USD")
  skills               Json             @default("[]")
  description          String?          @db.Text
  status               JobRoleStatus    @default(ACTIVE)
  openPositions        Int              @default(1) @map("open_positions")
  applicationsReceived Int              @default(0) @map("applications_received")
  assessmentLanguages  Json             @default("[\"PYTHON\"]") @map("assessment_languages")
  closingDate          DateTime?        @map("closing_date")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  candidates  CandidateProfile[]
  assessments Assessment[]
  questions   Question[]

  @@index([status])
  @@map("job_roles")
}

model Referral {
  id           String   @id @default(uuid())
  employeeId   String   @unique @map("employee_id")
  employeeName String?  @map("employee_name")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("referrals")
}

model AssessmentToken {
  id          String      @id @default(uuid())
  candidateId String      @map("candidate_id")
  jti         String      @unique
  email       String
  status      TokenStatus @default(CREATED)
  expiresAt   DateTime    @map("expires_at")
  usedAt      DateTime?   @map("used_at")
  isRevoked   Boolean     @default(false) @map("is_revoked")
  createdAt   DateTime    @default(now()) @map("created_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([status])
  @@map("assessment_tokens")
}

model EmailVerificationToken {
  id          String    @id @default(uuid())
  candidateId String    @map("candidate_id")
  jti         String    @unique
  email       String
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  candidate CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("email_verification_tokens")
}

model Assessment {
  id          String           @id @default(uuid())
  candidateId String           @map("candidate_id")
  jobRoleId   String?          @map("job_role_id")
  language    Language
  status      AssessmentStatus @default(PENDING)
  questionIds Json             @map("question_ids")
  startedAt   DateTime?        @map("started_at")
  expiresAt   DateTime?        @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  candidate  CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobRole    JobRole?         @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)
  submission Submission?

  @@index([candidateId, status])
  @@index([jobRoleId])
  @@map("assessments")
}

model Question {
  id                 String              @id @default(uuid())
  jobRoleId          String?             @map("job_role_id")
  experienceCategory ExperienceCategory? @map("experience_category")
  answerMode         AnswerMode          @default(CODE) @map("answer_mode")
  language           Language
  title              String
  description        String              @db.Text
  inputFormat        String              @map("input_format") @db.Text
  outputFormat       String              @map("output_format") @db.Text
  sampleInput        String              @map("sample_input") @db.Text
  sampleOutput       String              @map("sample_output") @db.Text
  constraints        String              @db.Text
  difficulty         Difficulty
  topic              String
  starterCode        String              @map("starter_code") @db.Text
  mcqOptions         Json?               @map("mcq_options")
  correctOptionIndex Int?                @map("correct_option_index")
  explanation        String?             @db.Text
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  testCases         QuestionTestCase[]
  submissionAnswers SubmissionAnswer[]
  jobRole           JobRole?           @relation(fields: [jobRoleId], references: [id], onDelete: SetNull)

  @@index([language, isActive])
  @@index([jobRoleId])
  @@index([experienceCategory])
  @@map("questions")
}

model QuestionTestCase {
  id             String  @id @default(uuid())
  questionId     String  @map("question_id")
  input          String  @db.Text
  expectedOutput String  @map("expected_output") @db.Text
  isHidden       Boolean @default(true) @map("is_hidden")
  sortOrder      Int     @default(0) @map("sort_order")

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("question_testcases")
}

model Submission {
  id              String    @id @default(uuid())
  assessmentId    String    @unique @map("assessment_id")
  candidateId     String    @map("candidate_id")
  score           Decimal   @db.Decimal(5, 2)
  passedQuestions Int       @map("passed_questions")
  totalQuestions  Int       @map("total_questions")
  aiReviewStatus  String    @default("PENDING") @map("ai_review_status")
  aiReview        Json?     @map("ai_review")
  aiReviewError   String?   @map("ai_review_error") @db.Text
  aiReviewedAt    DateTime? @map("ai_reviewed_at")
  submittedAt     DateTime  @default(now()) @map("submitted_at")

  assessment Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  candidate  CandidateProfile   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  answers    SubmissionAnswer[]

  @@index([candidateId])
  @@map("submissions")
}

model SubmissionAnswer {
  id                  String  @id @default(uuid())
  submissionId        String  @map("submission_id")
  questionId          String  @map("question_id")
  code                String  @db.Text
  selectedOptionIndex Int?    @map("selected_option_index")
  passedTests         Int     @default(0) @map("passed_tests")
  failedTests         Int     @default(0) @map("failed_tests")
  executionTimeMs     Int?    @map("execution_time_ms")
  memoryKb            Int?    @map("memory_kb")
  testResults         Json?   @map("test_results")
  isFullyPassed       Boolean @default(false) @map("is_fully_passed")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id])

  @@index([submissionId])
  @@map("submission_answers")
}

model AdminUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String    @map("password_hash")
  role         AdminRole @default(ADMIN)
  createdById  String?   @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLoginAt  DateTime? @map("last_login_at")

  createdBy                AdminUser?              @relation("AdminCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAdmins            AdminUser[]             @relation("AdminCreatedBy")
  auditLogs                AuditLog[]
  deletedCandidates        CandidateProfile[]      @relation("CandidateDeletedBy")
  restoredCandidates       CandidateProfile[]      @relation("CandidateRestoredBy")
  rejectedCandidates       CandidateProfile[]      @relation("CandidateRejectedBy")
  rejectionHistory         CandidateRejection[]    @relation("CandidateRejectionBy")
  bulkOperations           AdminBulkOperation[]
  reminderTemplates        EmailReminderTemplate[]
  reminderTemplatesUpdated EmailReminderTemplate[] @relation("ReminderTemplateUpdatedBy")
  reminderDeliveries       EmailReminderDelivery[]
  interviewsScheduled      CandidateInterview[]
  googleCalendars          AdminGoogleCalendar[]
  idempotencyRecords       IdempotencyRecord[]

  @@map("admin_users")
}

enum BulkOperationAction {
  STATUS_CHANGE
  REMINDER
  ASSIGN_ROLE
  REJECT
  SOFT_DELETE
  RESTORE
  PERMANENT_DELETE
  EXPORT
  SCHEDULE_INTERVIEW
}

enum BulkOperationStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL
  FAILED
}

enum ReminderDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum InterviewStatus {
  PENDING
  CONFIRMED
  FAILED
  CANCELLED
  COMPLETED
}

enum InterviewMode {
  SINGLE
  GROUP
  SEQUENTIAL
}

enum CalendarConnectionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model AdminBulkOperation {
  id             String              @id @default(uuid())
  operationId    String              @unique @map("operation_id")
  action         BulkOperationAction
  status         BulkOperationStatus @default(PENDING)
  adminUserId    String              @map("admin_user_id")
  actorRole      AdminRole?          @map("actor_role")
  selectionMode  String              @map("selection_mode")
  filterSnapshot Json?               @map("filter_snapshot")
  excludedCount  Int                 @default(0) @map("excluded_count")
  requestedCount Int                 @default(0) @map("requested_count")
  succeededCount Int                 @default(0) @map("succeeded_count")
  failedCount    Int                 @default(0) @map("failed_count")
  skippedCount   Int                 @default(0) @map("skipped_count")
  requestId      String?             @map("request_id")
  metadata       Json?
  errorSummary   String?             @map("error_summary") @db.Text
  ipAddress      String?             @map("ip_address")
  userAgent      String?             @map("user_agent")
  createdAt      DateTime            @default(now()) @map("created_at")
  completedAt    DateTime?           @map("completed_at")

  // Retain bulk audit history even if an admin account is removed.
  adminUser AdminUser                @relation(fields: [adminUserId], references: [id], onDelete: Restrict)
  items     AdminBulkOperationItem[]

  @@index([adminUserId])
  @@index([adminUserId, createdAt])
  @@index([action])
  @@index([action, createdAt])
  @@index([createdAt])
  @@index([operationId])
  @@map("admin_bulk_operations")
}

model AdminBulkOperationItem {
  id                 String   @id @default(uuid())
  operationId        String   @map("operation_id")
  candidateId        String?  @map("candidate_id")
  candidateReference String?  @map("candidate_reference")
  status             String
  errorCode          String?  @map("error_code")
  errorMessage       String?  @map("error_message")
  previousValue      Json?    @map("previous_value")
  newValue           Json?    @map("new_value")
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")

  operation AdminBulkOperation @relation(fields: [operationId], references: [operationId], onDelete: Cascade)
  candidate CandidateProfile?  @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([operationId])
  @@index([candidateId])
  @@map("admin_bulk_operation_items")
}

model EmailReminderTemplate {
  id          String   @id @default(uuid())
  type        String   @default("REMINDER") @map("type")
  name        String
  subject     String
  bodyHtml    String   @map("body_html") @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdById String?  @map("created_by_id")
  updatedById String?  @map("updated_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy  AdminUser?              @relation(fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy  AdminUser?              @relation("ReminderTemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deliveries EmailReminderDelivery[]

  @@index([isActive])
  @@index([type, isActive])
  @@map("email_reminder_templates")
}

model EmailReminderDelivery {
  id                 String                 @id @default(uuid())
  operationId        String                 @map("operation_id")
  candidateId        String?                @map("candidate_id")
  candidateReference String?                @map("candidate_reference")
  templateId         String                 @map("template_id")
  adminUserId        String                 @map("admin_user_id")
  recipientEmail     String                 @map("recipient_email")
  subjectRendered    String                 @map("subject_rendered")
  status             ReminderDeliveryStatus @default(PENDING)
  errorCode          String?                @map("error_code")
  errorSummary       String?                @map("error_summary")
  sentAt             DateTime?              @map("sent_at")
  createdAt          DateTime               @default(now()) @map("created_at")
  updatedAt          DateTime               @updatedAt @map("updated_at")

  candidate CandidateProfile?     @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  template  EmailReminderTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  adminUser AdminUser             @relation(fields: [adminUserId], references: [id], onDelete: Restrict)

  @@unique([operationId, candidateId])
  @@index([operationId])
  @@index([candidateId])
  @@index([candidateId, createdAt])
  @@index([status])
  @@index([createdAt])
  @@map("email_reminder_deliveries")
}

model CandidateInterview {
  id                 String          @id @default(uuid())
  idempotencyKey     String          @unique @map("idempotency_key")
  operationId        String?         @map("operation_id")
  mode               InterviewMode   @default(SINGLE)
  title              String
  notes              String?         @db.Text
  startUtc           DateTime        @map("start_utc")
  endUtc             DateTime        @map("end_utc")
  timezone           String
  durationMinutes    Int             @map("duration_minutes")
  gapMinutes         Int             @default(0) @map("gap_minutes")
  status             InterviewStatus @default(PENDING)
  calendarProvider   String          @default("GOOGLE") @map("calendar_provider")
  googleEventId      String?         @map("google_event_id")
  meetUrl            String?         @map("meet_url")
  calendarOwnerEmail String?         @map("calendar_owner_email")
  failureCode        String?         @map("failure_code")
  failureSummary     String?         @map("failure_summary") @db.Text
  emailStatus        String?         @map("email_status")
  scheduledByAdminId String          @map("scheduled_by_admin_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  cancelledAt        DateTime?       @map("cancelled_at")

  scheduledBy  AdminUser                       @relation(fields: [scheduledByAdminId], references: [id], onDelete: Restrict)
  participants CandidateInterviewParticipant[]

  @@unique([googleEventId])
  @@index([scheduledByAdminId])
  @@index([scheduledByAdminId, createdAt])
  @@index([status])
  @@index([startUtc])
  @@index([operationId])
  @@map("candidate_interviews")
}

model CandidateInterviewParticipant {
  id                 String   @id @default(uuid())
  interviewId        String   @map("interview_id")
  candidateId        String?  @map("candidate_id")
  candidateReference String?  @map("candidate_reference")
  startUtc           DateTime @map("start_utc")
  endUtc             DateTime @map("end_utc")
  googleEventId      String?  @map("google_event_id")
  meetUrl            String?  @map("meet_url")
  emailStatus        String?  @map("email_status")
  createdAt          DateTime @default(now()) @map("created_at")

  interview CandidateInterview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  candidate CandidateProfile?  @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@unique([interviewId, candidateId])
  @@index([candidateId])
  @@index([candidateId, startUtc])
  @@map("candidate_interview_participants")
}

model AdminGoogleCalendar {
  id                    String                   @id @default(uuid())
  adminUserId           String                   @map("admin_user_id")
  provider              String                   @default("GOOGLE")
  googleEmail           String                   @map("google_email")
  refreshTokenEncrypted String                   @map("refresh_token_encrypted") @db.Text
  grantedScopes         String                   @default("https://www.googleapis.com/auth/calendar.events") @map("granted_scopes") @db.Text
  status                CalendarConnectionStatus @default(ACTIVE)
  connectedAt           DateTime                 @default(now()) @map("connected_at")
  revokedAt             DateTime?                @map("revoked_at")
  createdAt             DateTime                 @default(now()) @map("created_at")
  updatedAt             DateTime                 @updatedAt @map("updated_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, provider, googleEmail])
  @@index([adminUserId, status])
  @@map("admin_google_calendars")
}

/// Generic idempotency for reminder sends and other retry-sensitive admin actions.
model IdempotencyRecord {
  id             String   @id @default(uuid())
  key            String   @map("key")
  adminUserId    String   @map("admin_user_id")
  operationType  String   @map("operation_type")
  requestHash    String   @map("request_hash")
  responseStatus Int      @map("response_status")
  responseBody   Json?    @map("response_body")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@unique([adminUserId, operationType, key])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("idempotency_records")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("platform_settings")
}

model AuditLog {
  id          String   @id @default(uuid())
  adminUserId String?  @map("admin_user_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  ipAddress   String?  @map("ip_address")
  createdAt   DateTime @default(now()) @map("created_at")

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([createdAt])
  @@map("audit_logs")
}
