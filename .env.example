# Hurix Talent Assessment Platform - Environment Configuration

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://hurix:hurix_secret@localhost:5432/hurix_talent?schema=public
TEST_DATABASE_URL=postgresql://hurix:hurix_secret@localhost:5432/hurix_talent_test?schema=public

# JWT Secrets (CHANGE IN PRODUCTION)
JWT_ASSESSMENT_SECRET=change-this-to-a-long-random-assessment-secret
JWT_ADMIN_SECRET=change-this-to-a-long-random-admin-secret
ASSESSMENT_TOKEN_EXPIRY_DAYS=7
CANDIDATE_PORTAL_EXPIRY_DAYS=30
ADMIN_TOKEN_EXPIRY_HOURS=8

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# Supabase Auth (candidate authentication)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# AI Assessment Review
OPENAI_API_KEY=
AI_SCORING_MODEL=gpt-4o-mini

# Email (SMTP) — set EMAIL_MOCK_MODE=false and configure SMTP for real delivery
EMAIL_PROVIDER=smtp
EMAIL_MOCK_MODE=true
EMAIL_FROM=Hurix Talent <noreply@hurixdigital.com>
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Assessment Settings
ASSESSMENT_QUESTION_COUNT=10
ASSESSMENT_DURATION_MINUTES=15

# File Upload
MAX_RESUME_SIZE_MB=10
UPLOAD_DIR=./uploads/resumes
STORAGE_PROVIDER=local
# STORAGE_PROVIDER=supabase
# SUPABASE_RESUME_BUCKET=candidate-resumes

# S3 Storage (future)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# Docker Sandbox
SANDBOX_PYTHON_IMAGE=hurix-sandbox-python
SANDBOX_NODE_IMAGE=hurix-sandbox-node
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_TIMEOUT_SECONDS=10
SANDBOX_MOCK_MODE=true

# Admin Seed Credentials
ADMIN_EMAIL=admin@hurixdigital.com
ADMIN_PASSWORD=HurixAdmin@2026

# Google Calendar (interview scheduling)
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:4000/api/admin/calendar/callback
GOOGLE_CALENDAR_MOCK_MODE=true
TOKEN_ENCRYPTION_KEY=
BULK_OPERATION_MAX_CANDIDATES=5000
EMAIL_SEND_CONCURRENCY=5

# Frontend
VITE_API_URL=/api
